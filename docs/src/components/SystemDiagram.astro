---
interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const t = {
  en: {
    app: 'iPhone App',
    appSub: 'Navigation',
    espFront: 'ESP32 Front',
    espFrontSub: 'Master',
    espRear: 'ESP32 Rear',
    espRearSub: 'Slave',
    ble: 'Bluetooth LE',
    bt: 'Bluetooth Classic',
    ledFront: 'LED Strip',
    ledRear: 'LED Strip',
    sensors: '3× HC-SR04',
  },
  de: {
    app: 'iPhone App',
    appSub: 'Navigation',
    espFront: 'ESP32 Vorne',
    espFrontSub: 'Master',
    espRear: 'ESP32 Hinten',
    espRearSub: 'Slave',
    ble: 'Bluetooth LE',
    bt: 'Bluetooth Classic',
    ledFront: 'LED-Streifen',
    ledRear: 'LED-Streifen',
    sensors: '3× HC-SR04',
  },
}[lang];
---

<figure class="sd-wrap" aria-label="System architecture diagram">
  <svg
    class="sd-svg"
    viewBox="0 0 760 220"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label={lang === 'de' ? 'Systemarchitektur-Diagramm' : 'System architecture diagram'}
  >
    <defs>
      <!-- Cyan glow filter for boxes -->
      <filter id="glow-cyan" x="-30%" y="-60%" width="160%" height="220%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="glow-violet" x="-30%" y="-60%" width="160%" height="220%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <!-- Gradient for LED strips -->
      <linearGradient id="led-grad-front" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"   stop-color="rgba(25,227,255,0.6)"/>
        <stop offset="50%"  stop-color="rgba(124,92,255,0.7)"/>
        <stop offset="100%" stop-color="rgba(255,45,156,0.6)"/>
      </linearGradient>
      <linearGradient id="led-grad-rear" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"   stop-color="rgba(34,197,94,0.7)"/>
        <stop offset="50%"  stop-color="rgba(245,158,11,0.5)"/>
        <stop offset="100%" stop-color="rgba(255,45,156,0.7)"/>
      </linearGradient>
      <!-- Clip for LED segment mask -->
      <clipPath id="led-mask">
        <rect rx="4" ry="4"/>
      </clipPath>
    </defs>

    <!-- ── iPhone App ─────────────────────────────────────────── -->
    <rect class="sd-box sd-box-app" x="12" y="48" width="130" height="72" rx="10"/>
    <!-- Phone icon outline -->
    <rect x="62" y="58" width="28" height="42" rx="4" fill="none" stroke="rgba(124,92,255,.6)" stroke-width="1.5"/>
    <circle cx="76" cy="94" r="2.5" fill="rgba(124,92,255,.7)"/>
    <rect x="71" y="60" width="10" height="2" rx="1" fill="rgba(124,92,255,.5)"/>
    <text class="sd-label" x="76" y="110">{t.app}</text>
    <text class="sd-sub" x="76" y="122">{t.appSub}</text>

    <!-- ── BLE connection line ───────────────────────────────── -->
    <line class="sd-line sd-ble-line" x1="143" y1="84" x2="280" y2="84"/>
    <!-- Arrow head -->
    <polygon class="sd-arrow sd-ble-arrow" points="280,80 290,84 280,88"/>
    <text class="sd-conn-label" x="216" y="77">{t.ble}</text>

    <!-- ── ESP32 Front ───────────────────────────────────────── -->
    <rect class="sd-box sd-box-esp" x="290" y="48" width="150" height="72" rx="10"/>
    <!-- Chip icon -->
    <rect x="345" y="62" width="40" height="30" rx="3" fill="none" stroke="rgba(25,227,255,.5)" stroke-width="1.5"/>
    <rect x="349" y="66" width="32" height="22" rx="2" fill="rgba(25,227,255,.08)"/>
    <!-- Chip pins -->
    <line x1="345" y1="70" x2="340" y2="70" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="345" y1="76" x2="340" y2="76" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="345" y1="82" x2="340" y2="82" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="385" y1="70" x2="390" y2="70" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="385" y1="76" x2="390" y2="76" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="385" y1="82" x2="390" y2="82" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <text class="sd-label" x="365" y="110">{t.espFront}</text>
    <text class="sd-sub" x="365" y="122">{t.espFrontSub}</text>

    <!-- Front LED strip (below ESP32 Front box) -->
    <rect class="sd-led-bg" x="290" y="132" width="150" height="10" rx="5"/>
    <rect class="sd-led sd-led-front" x="292" y="133" width="146" height="8" rx="4"/>
    <text class="sd-led-label" x="365" y="155">{t.ledFront}</text>

    <!-- ── BT Classic connection line ───────────────────────── -->
    <line class="sd-line sd-bt-line" x1="441" y1="84" x2="578" y2="84"/>
    <polygon class="sd-arrow sd-bt-arrow" points="578,80 588,84 578,88"/>
    <text class="sd-conn-label" x="510" y="77">{t.bt}</text>

    <!-- ── ESP32 Rear ────────────────────────────────────────── -->
    <rect class="sd-box sd-box-esp" x="588" y="48" width="150" height="72" rx="10"/>
    <!-- Chip icon (same as front) -->
    <rect x="643" y="62" width="40" height="30" rx="3" fill="none" stroke="rgba(25,227,255,.5)" stroke-width="1.5"/>
    <rect x="647" y="66" width="32" height="22" rx="2" fill="rgba(25,227,255,.08)"/>
    <line x1="643" y1="70" x2="638" y2="70" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="643" y1="76" x2="638" y2="76" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="643" y1="82" x2="638" y2="82" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="683" y1="70" x2="688" y2="70" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="683" y1="76" x2="688" y2="76" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <line x1="683" y1="82" x2="688" y2="82" stroke="rgba(25,227,255,.4)" stroke-width="1.5"/>
    <text class="sd-label" x="663" y="110">{t.espRear}</text>
    <text class="sd-sub" x="663" y="122">{t.espRearSub}</text>

    <!-- Rear LED strip -->
    <rect class="sd-led-bg" x="588" y="132" width="150" height="10" rx="5"/>
    <rect class="sd-led sd-led-rear" x="590" y="133" width="146" height="8" rx="4"/>
    <text class="sd-led-label" x="663" y="155">{t.ledRear}</text>

    <!-- Sensor lines (up from rear) -->
    <line x1="623" y1="48" x2="623" y2="32" stroke="rgba(255,45,156,.35)" stroke-width="1.5" stroke-dasharray="3 3"/>
    <line x1="663" y1="48" x2="663" y2="28" stroke="rgba(255,45,156,.4)"  stroke-width="1.5" stroke-dasharray="3 3"/>
    <line x1="703" y1="48" x2="703" y2="32" stroke="rgba(255,45,156,.35)" stroke-width="1.5" stroke-dasharray="3 3"/>
    <!-- Sensor icons -->
    <rect class="sd-sensor" x="610" y="18" width="26" height="14" rx="3"/>
    <rect class="sd-sensor" x="650" y="14" width="26" height="14" rx="3"/>
    <rect class="sd-sensor" x="690" y="18" width="26" height="14" rx="3"/>
    <!-- Sensor pulse arcs -->
    <path class="sd-sensor-arc" d="M 608 18 Q 623 4 638 18" fill="none"/>
    <path class="sd-sensor-arc" d="M 648 14 Q 663 0 678 14" fill="none"/>
    <path class="sd-sensor-arc" d="M 688 18 Q 703 4 718 18" fill="none"/>
    <text class="sd-sensor-label" x="663" y="8">{t.sensors}</text>
  </svg>
</figure>

<style>
  .sd-wrap {
    margin: 1.5rem 0;
    padding: 0;
    border: none;
  }

  .sd-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* ── Boxes ──────────────────────────────────────────────────── */
  .sd-box {
    stroke-width: 1.5;
    fill: var(--amb-surface-2, #0E121C);
  }
  .sd-box-app {
    stroke: rgba(124,92,255,.5);
    filter: drop-shadow(0 0 8px rgba(124,92,255,.25));
  }
  .sd-box-esp {
    stroke: rgba(25,227,255,.4);
    filter: drop-shadow(0 0 8px rgba(25,227,255,.2));
  }

  /* ── Connection lines (animated dashoffset = flowing dots) ── */
  .sd-line {
    stroke-width: 1.5;
    fill: none;
  }
  .sd-ble-line {
    stroke: rgba(25,227,255,.5);
    stroke-dasharray: 6 5;
    animation: flow-right 1.4s linear infinite;
  }
  .sd-bt-line {
    stroke: rgba(124,92,255,.5);
    stroke-dasharray: 6 5;
    animation: flow-right 1.4s linear infinite 0.4s;
  }

  .sd-arrow {
    fill-opacity: 0;
    stroke-width: 1;
  }
  .sd-ble-arrow { fill: rgba(25,227,255,.6); fill-opacity: 1; }
  .sd-bt-arrow  { fill: rgba(124,92,255,.6); fill-opacity: 1; }

  /* ── Labels ─────────────────────────────────────────────────── */
  .sd-label {
    fill: var(--amb-text, #EEF2FA);
    font-family: var(--font-display, "Space Grotesk", sans-serif);
    font-size: 10px;
    font-weight: 600;
    text-anchor: middle;
    dominant-baseline: auto;
  }
  .sd-sub {
    fill: var(--amb-text-4, #6B7488);
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 8px;
    text-anchor: middle;
  }
  .sd-conn-label {
    fill: var(--amb-text-4, #6B7488);
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 7.5px;
    letter-spacing: 0.06em;
    text-anchor: middle;
  }
  .sd-led-label {
    fill: var(--amb-text-4, #6B7488);
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 7.5px;
    text-anchor: middle;
  }
  .sd-sensor-label {
    fill: var(--amb-magenta-soft, #FF6FC2);
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 7.5px;
    text-anchor: middle;
  }

  /* ── LED strips ─────────────────────────────────────────────── */
  .sd-led-bg {
    fill: rgba(255,255,255,.03);
    stroke: var(--amb-line, rgba(255,255,255,.08));
    stroke-width: 1;
  }
  .sd-led {
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .sd-led-front {
    fill: url(#led-grad-front);
    animation-name: led-ambient-pulse;
    animation-duration: 3s;
  }
  .sd-led-rear {
    fill: url(#led-grad-rear);
    animation-name: led-ambient-pulse;
    animation-duration: 3s;
    animation-delay: 1.5s;
  }

  /* ── Sensors ─────────────────────────────────────────────────── */
  .sd-sensor {
    fill: var(--amb-surface-3, #151A26);
    stroke: rgba(255,45,156,.45);
    stroke-width: 1.2;
  }
  .sd-sensor-arc {
    stroke: rgba(255,45,156,.35);
    stroke-width: 1;
    stroke-dasharray: 3 3;
    animation: sensor-ping 2s ease-in-out infinite;
  }

  /* ── Light mode ─────────────────────────────────────────────── */
  :global([data-theme='light']) .sd-box {
    fill: #EEF2FA;
  }
  :global([data-theme='light']) .sd-box-app {
    stroke: rgba(124,92,255,.6);
    filter: none;
  }
  :global([data-theme='light']) .sd-box-esp {
    stroke: rgba(0,150,176,.5);
    filter: none;
  }
  :global([data-theme='light']) .sd-label {
    fill: #151A26;
  }
  :global([data-theme='light']) .sd-led-bg {
    fill: rgba(0,0,0,.04);
    stroke: rgba(0,0,0,.10);
  }

  /* ── Keyframes ───────────────────────────────────────────────── */
  @keyframes flow-right {
    from { stroke-dashoffset: 22; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes led-ambient-pulse {
    0%, 100% { opacity: 0.6; }
    50%       { opacity: 1.0; }
  }

  @keyframes sensor-ping {
    0%, 100% { opacity: 0.2; stroke-dashoffset: 0; }
    40%       { opacity: 0.7; stroke-dashoffset: -8; }
    70%       { opacity: 0.3; stroke-dashoffset: -14; }
  }
</style>
