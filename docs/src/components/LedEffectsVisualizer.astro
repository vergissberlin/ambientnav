---
// LED effects visualizer — CSS-animated previews for all front and rear strip effects.
---

<section class="le" aria-label="LED Effects Visualizer">

  <!-- ── Front strip ─────────────────────────────────────────── -->
  <h3 class="le-heading">Front LEDs — Navigation</h3>

  <div class="le-grid">

    <!-- AMBIENT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Ambient Glow</span>
        <span class="le-badge le-badge-violet">Violet</span>
      </div>
      <div class="le-strip le-seg">
        <div class="le-fill le-ambient"></div>
      </div>
      <p class="le-note">Calm breathing light · No active navigation</p>
    </div>

    <!-- NAV_LEFT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Turn Left</span>
        <span class="le-badge le-badge-cyan">Cyan</span>
      </div>
      <div class="le-strip le-seg le-clip">
        <div class="le-fill le-sweep-base le-sweep-left-grad"></div>
        <div class="le-fill le-sweep-left le-sweep-left-grad"></div>
      </div>
      <p class="le-note">Light sweeps left · Next left turn within 200 m</p>
    </div>

    <!-- NAV_RIGHT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Turn Right</span>
        <span class="le-badge le-badge-cyan">Cyan</span>
      </div>
      <div class="le-strip le-seg le-clip">
        <div class="le-fill le-sweep-base le-sweep-right-grad"></div>
        <div class="le-fill le-sweep-right le-sweep-right-grad"></div>
      </div>
      <p class="le-note">Light sweeps right · Next right turn within 200 m</p>
    </div>

    <!-- NAV_STRAIGHT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Go Straight</span>
        <span class="le-badge le-badge-white">White</span>
      </div>
      <div class="le-strip le-seg">
        <div class="le-fill le-straight"></div>
      </div>
      <p class="le-note">Soft center pulse · Continue straight ahead</p>
    </div>

    <!-- BLINKER_LEFT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Left Indicator</span>
        <span class="le-badge le-badge-violet">Violet</span>
      </div>
      <div class="le-strip le-seg le-clip">
        <div class="le-fill le-half-left le-blink"></div>
      </div>
      <p class="le-note">Left half blinks · Left indicator is active</p>
    </div>

    <!-- BLINKER_RIGHT -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Right Indicator</span>
        <span class="le-badge le-badge-violet">Violet</span>
      </div>
      <div class="le-strip le-seg le-clip">
        <div class="le-fill le-half-right le-blink"></div>
      </div>
      <p class="le-note">Right half blinks · Right indicator is active</p>
    </div>

    <!-- HAZARD -->
    <div class="le-card">
      <div class="le-card-header">
        <span class="le-label">Hazard</span>
        <span class="le-badge le-badge-magenta">Pink</span>
      </div>
      <div class="le-strip le-seg">
        <div class="le-fill le-hazard le-blink"></div>
      </div>
      <p class="le-note">Full strip blinks · Hazard lights are active</p>
    </div>

  </div><!-- /le-grid -->

  <!-- ── Rear strip ──────────────────────────────────────────── -->
  <h3 class="le-heading le-heading-rear">Rear LEDs — Parking</h3>
  <p class="le-intro">Three zones — left, center, right — each track one distance sensor. The bar shrinks and shifts color as an obstacle gets closer. Active only when reverse gear is engaged.</p>

  <div class="le-rear-layout">

    <div class="le-zones" id="leZones">
      <div class="le-zone-row">
        <span class="le-zone-tag">Left</span>
        <div class="le-strip le-seg le-clip le-strip-rear">
          <div class="le-zone-bar" id="leZone0"></div>
        </div>
        <span class="le-zone-dist" id="leDist0">—</span>
      </div>
      <div class="le-zone-row">
        <span class="le-zone-tag">Center</span>
        <div class="le-strip le-seg le-clip le-strip-rear">
          <div class="le-zone-bar" id="leZone1"></div>
        </div>
        <span class="le-zone-dist" id="leDist1">—</span>
      </div>
      <div class="le-zone-row">
        <span class="le-zone-tag">Right</span>
        <div class="le-strip le-seg le-clip le-strip-rear">
          <div class="le-zone-bar" id="leZone2"></div>
        </div>
        <span class="le-zone-dist" id="leDist2">—</span>
      </div>
    </div>

    <div class="le-legend">
      <div class="le-legend-title">Distance</div>
      <div class="le-legend-row">
        <span class="le-swatch" style="background:#19E3FF; box-shadow: 0 0 6px rgba(25,227,255,.6)"></span>
        <span class="le-legend-range">Clear</span>
        <span class="le-legend-detail">Full bar · safe distance</span>
      </div>
      <div class="le-legend-row">
        <span class="le-swatch" style="background:#7C5CFF; box-shadow: 0 0 6px rgba(124,92,255,.6)"></span>
        <span class="le-legend-range">Approaching</span>
        <span class="le-legend-detail">Bar shortens</span>
      </div>
      <div class="le-legend-row">
        <span class="le-swatch" style="background:#A040E0; box-shadow: 0 0 6px rgba(160,64,224,.6)"></span>
        <span class="le-legend-range">Closer</span>
        <span class="le-legend-detail">Half bar</span>
      </div>
      <div class="le-legend-row">
        <span class="le-swatch" style="background:#CC1C7C; box-shadow: 0 0 6px rgba(204,28,124,.6)"></span>
        <span class="le-legend-range">Close</span>
        <span class="le-legend-detail">Short bar</span>
      </div>
      <div class="le-legend-row">
        <span class="le-swatch" style="background:#FF2D9C; box-shadow: 0 0 6px rgba(255,45,156,.6)"></span>
        <span class="le-legend-range">Stop!</span>
        <span class="le-legend-detail">Blinking · very close</span>
      </div>
    </div>

  </div><!-- /le-rear-layout -->

</section>

<script>
  const STATES = [
    { label: 'Clear',       color: '#19E3FF', glow: 'rgba(25,227,255,.55)',   fill: 1.00, blink: false },
    { label: 'Approaching', color: '#7C5CFF', glow: 'rgba(124,92,255,.5)',    fill: 0.80, blink: false },
    { label: 'Closer',      color: '#A040E0', glow: 'rgba(160,64,224,.5)',    fill: 0.50, blink: false },
    { label: 'Close',       color: '#CC1C7C', glow: 'rgba(204,28,124,.5)',    fill: 0.20, blink: false },
    { label: 'Stop!',       color: '#FF2D9C', glow: 'rgba(255,45,156,.6)',    fill: 0.10, blink: true  },
  ];

  // Each zone starts at a different state so all distances are visible simultaneously
  const ZONE_OFFSETS = [0, 2, 4];
  const HOLD_MS = 2800;

  let step = 0;
  let timer: ReturnType<typeof setTimeout> | null = null;

  function renderZone(zoneIdx: number, stateIdx: number) {
    const bar  = document.getElementById(`leZone${zoneIdx}`);
    const dist = document.getElementById(`leDist${zoneIdx}`);
    if (!bar || !dist) return;

    const s = STATES[stateIdx % STATES.length];
    bar.style.width      = `${s.fill * 100}%`;
    bar.style.background = s.color;
    bar.style.boxShadow  = `0 0 14px ${s.glow}`;
    bar.style.opacity    = '1';

    if (s.blink) {
      bar.classList.add('le-zone-blink');
    } else {
      bar.classList.remove('le-zone-blink');
    }

    dist.textContent   = s.label;
    (dist as HTMLElement).style.color = s.color;
  }

  function tick() {
    for (let z = 0; z < 3; z++) {
      renderZone(z, (step + ZONE_OFFSETS[z]) % STATES.length);
    }
    step = (step + 1) % STATES.length;
    timer = setTimeout(tick, HOLD_MS);
  }

  function init() {
    if (timer) clearTimeout(timer);
    step = 0;
    tick();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:after-swap', init);
  if (document.readyState !== 'loading') init();
</script>

<style>
  /* ── Layout ──────────────────────────────────────────────────────── */
  .le {
    margin: 1.5rem 0 2.5rem;
  }

  .le-heading {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--sl-color-text-accent, var(--amb-text-2, #C7CEDC));
    margin: 2rem 0 0.8rem;
    padding-top: 1rem;
    border-top: 1px solid var(--amb-line, rgba(255,255,255,.08));
    text-transform: uppercase;
  }
  .le-heading-rear { margin-top: 2.5rem; }

  .le-intro {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    color: var(--amb-text-4, #6B7488);
    line-height: 1.55;
  }

  /* ── Card grid ───────────────────────────────────────────────────── */
  .le-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.85rem;
  }

  .le-card {
    background: var(--amb-surface, #0B0F18);
    border: 1px solid var(--amb-line, rgba(255,255,255,.08));
    border-radius: 12px;
    padding: 1rem 1rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    transition: border-color 200ms;
  }
  .le-card:hover {
    border-color: var(--amb-line-strong, rgba(255,255,255,.18));
  }

  .le-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
  }

  .le-label {
    font-family: var(--font-display, "Space Grotesk", system-ui, sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--amb-text-2, #C7CEDC);
  }

  .le-badge {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.18em 0.6em;
    border-radius: 999px;
    white-space: nowrap;
  }
  .le-badge-cyan {
    color: var(--amb-cyan, #19E3FF);
    background: rgba(25,227,255,.08);
    border: 1px solid rgba(25,227,255,.22);
  }
  .le-badge-violet {
    color: var(--amb-violet-soft, #A38CFF);
    background: rgba(124,92,255,.10);
    border: 1px solid rgba(124,92,255,.25);
  }
  .le-badge-magenta {
    color: var(--amb-magenta-soft, #FF6FC2);
    background: rgba(255,45,156,.10);
    border: 1px solid rgba(255,45,156,.25);
  }
  .le-badge-white {
    color: #b8c4d8;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.13);
  }

  .le-note {
    margin: 0;
    font-size: 0.76rem;
    color: var(--amb-text-4, #6B7488);
    line-height: 1.5;
  }

  /* ── LED strip ───────────────────────────────────────────────────── */
  .le-strip {
    height: 12px;
    border-radius: 999px;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--amb-line, rgba(255,255,255,.08));
    position: relative;
  }

  /* Segmented LED look — 60 LEDs with 1px gaps */
  .le-seg {
    mask-image: repeating-linear-gradient(
      90deg,
      #000 0px,
      #000 calc(100% / 60 - 1px),
      transparent calc(100% / 60 - 1px),
      transparent calc(100% / 60)
    );
  }

  .le-clip { overflow: hidden; }

  .le-strip-rear { height: 14px; }

  /* ── Fill layers (absolute, cover the strip) ─────────────────────── */
  .le-fill {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  /* AMBIENT: violet-to-magenta gradient breathing */
  .le-ambient {
    background: linear-gradient(90deg,
      rgba(124,92,255,.80) 0%,
      rgba(180,60,200,.85) 50%,
      rgba(255,45,156,.75) 100%
    );
    box-shadow: 0 0 18px rgba(124,92,255,.35);
    animation: le-breathe 3000ms ease-in-out infinite;
  }

  /* NAV_STRAIGHT: white center pulse */
  .le-straight {
    background: radial-gradient(ellipse 38% 100% at 50% 50%,
      rgba(255,255,255,.96) 0%,
      rgba(200,248,255,.55) 45%,
      transparent 72%);
    animation: le-breathe 800ms ease-in-out infinite;
  }

  /* HAZARD: full magenta bar */
  .le-hazard {
    background: rgba(255,45,156,.92);
    box-shadow: 0 0 18px rgba(255,45,156,.55);
  }

  /* ── Sweep (NAV_LEFT / NAV_RIGHT) — cyan ─────────────────────────── */
  .le-sweep-left-grad {
    background: linear-gradient(90deg,
      rgba(25,227,255,.0)  0%,
      rgba(25,227,255,.9) 12%,
      rgba(25,227,255,.55) 35%,
      rgba(25,227,255,.0) 60%
    );
  }
  .le-sweep-right-grad {
    background: linear-gradient(90deg,
      rgba(25,227,255,.0)  40%,
      rgba(25,227,255,.55) 65%,
      rgba(25,227,255,.9) 88%,
      rgba(25,227,255,.0) 100%
    );
  }

  /* Base layer — dim, static hint at center */
  .le-sweep-base {
    opacity: 0.18;
    background-position: center;
  }

  /* Animated layer — moves from center toward edge */
  .le-sweep-left {
    animation: le-sweep-l 600ms linear infinite;
  }
  .le-sweep-right {
    animation: le-sweep-r 600ms linear infinite;
  }

  /* ── Blinker halves — violet ─────────────────────────────────────── */
  .le-half-left {
    left: 0;
    right: 50%;
    background: rgba(124,92,255,.92);
    box-shadow: 0 0 14px rgba(124,92,255,.55);
  }
  .le-half-right {
    left: 50%;
    right: 0;
    background: rgba(124,92,255,.92);
    box-shadow: 0 0 14px rgba(124,92,255,.55);
  }

  /* Blink: step animation for exact on/off */
  .le-blink {
    animation: le-blink 400ms steps(1) infinite;
  }

  /* ── Rear zones ──────────────────────────────────────────────────── */
  .le-rear-layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .le-zones {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .le-zone-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .le-zone-tag {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amb-text-4, #6B7488);
    width: 3.8rem;
    flex-shrink: 0;
  }

  .le-zone-bar {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    border-radius: inherit;
    width: 0;
    transition: width 600ms ease-in-out, background 600ms ease-in-out, box-shadow 600ms ease-in-out;
  }

  .le-zone-blink {
    animation: le-blink 200ms steps(1) infinite;
  }

  .le-zone-dist {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.68rem;
    font-weight: 500;
    min-width: 5.5rem;
    color: var(--amb-text-4, #6B7488);
    transition: color 400ms;
  }

  /* ── Legend ──────────────────────────────────────────────────────── */
  .le-legend {
    background: var(--amb-surface, #0B0F18);
    border: 1px solid var(--amb-line, rgba(255,255,255,.08));
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex-shrink: 0;
  }

  .le-legend-title {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amb-text-4, #6B7488);
    margin-bottom: 0.25rem;
  }

  .le-legend-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.72rem;
    color: var(--amb-text-2, #C7CEDC);
  }

  .le-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .le-legend-range {
    width: 6rem;
    flex-shrink: 0;
  }

  .le-legend-detail {
    color: var(--amb-text-4, #6B7488);
    font-size: 0.68rem;
  }

  /* ── Light-mode adjustments ──────────────────────────────────────── */
  :global([data-theme='light']) .le-card,
  :global([data-theme='light']) .le-legend {
    background: #F0F3FA;
    border-color: rgba(0,0,0,.09);
  }
  :global([data-theme='light']) .le-card:hover {
    border-color: rgba(0,0,0,.2);
  }
  :global([data-theme='light']) .le-strip {
    background: rgba(0,0,0,.05);
    border-color: rgba(0,0,0,.1);
  }
  :global([data-theme='light']) .le-heading {
    border-color: rgba(0,0,0,.09);
    color: #3a4055;
  }
  :global([data-theme='light']) .le-label {
    color: #2a3040;
  }
  :global([data-theme='light']) .le-note,
  :global([data-theme='light']) .le-intro {
    color: #5e6880;
  }
  :global([data-theme='light']) .le-ambient {
    background: linear-gradient(90deg,
      rgba(124,92,255,.60) 0%,
      rgba(180,60,200,.65) 50%,
      rgba(255,45,156,.55) 100%
    );
  }
  :global([data-theme='light']) .le-legend-title {
    color: #7a8399;
  }
  :global([data-theme='light']) .le-badge-cyan {
    color: #006ba8;
    background: rgba(0,107,168,.07);
    border-color: rgba(0,107,168,.18);
  }

  /* ── Mobile ──────────────────────────────────────────────────────── */
  @media (max-width: 540px) {
    .le-grid { grid-template-columns: 1fr; }
    .le-rear-layout { flex-direction: column; }
    .le-legend { width: 100%; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     KEYFRAMES
  ═══════════════════════════════════════════════════════════════════ */

  @keyframes le-breathe {
    0%, 100% { opacity: 0.10; }
    50%       { opacity: 1;    }
  }

  @keyframes le-blink {
    0%, 49%   { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  @keyframes le-sweep-l {
    from { transform: translateX(0%);    }
    to   { transform: translateX(-100%); }
  }

  @keyframes le-sweep-r {
    from { transform: translateX(0%);   }
    to   { transform: translateX(100%); }
  }
</style>
