---
interface Props {
  lang?: 'en' | 'de';
}
const { lang = 'en' } = Astro.props;

const t = {
  en: {
    eyebrow: 'Live LED Preview',
    front: 'Front',
    rear: 'Rear',
    modeAmbient: 'Ambient · Idle',
    modeLeft: 'Guide · Turn Left',
    modeRight: 'Guide · Turn Right',
    modeStraight: 'Guide · Straight Ahead',
    parkSafe: 'Park · Obstacle far',
    parkWarn: 'Park · Getting closer',
    parkDanger: 'Park · Stop now',
  },
  de: {
    eyebrow: 'LED-Vorschau',
    front: 'Vorne',
    rear: 'Hinten',
    modeAmbient: 'Ambient · Leerlauf',
    modeLeft: 'Führung · Links abbiegen',
    modeRight: 'Führung · Rechts abbiegen',
    modeStraight: 'Führung · Geradeaus',
    parkSafe: 'Parken · Hindernis weit',
    parkWarn: 'Parken · Näher werden',
    parkDanger: 'Parken · Stopp!',
  },
}[lang];
---

<section class="hv" aria-label={t.eyebrow}>
  <div class="hv-header">
    <span class="hv-eyebrow">{t.eyebrow}</span>
    <div class="hv-mode-labels" aria-live="polite" aria-atomic="true">
      <span class="hv-ml hv-ml-ambient">{t.modeAmbient}</span>
      <span class="hv-ml hv-ml-right">{t.modeRight}</span>
      <span class="hv-ml hv-ml-left">{t.modeLeft}</span>
      <span class="hv-ml hv-ml-straight">{t.modeStraight}</span>
    </div>
  </div>

  <div class="hv-stage">
    <!-- Front LED strip -->
    <div class="hv-row">
      <span class="hv-tag">{t.front}</span>
      <div class="hv-strip hv-front" role="img" aria-label="Front LED strip">
        <div class="hv-state hv-f-ambient"></div>
        <div class="hv-state hv-f-right"></div>
        <div class="hv-state hv-f-left"></div>
        <div class="hv-state hv-f-straight"></div>
      </div>
    </div>

    <!-- Car silhouette (top-down) -->
    <div class="hv-car" aria-hidden="true">
      <div class="hv-car-wheels hv-wheels-front">
        <div class="hv-wheel"></div>
        <div class="hv-wheel"></div>
      </div>
      <div class="hv-car-body">
        <div class="hv-windshield hv-windshield-front"></div>
        <div class="hv-interior"></div>
        <div class="hv-windshield hv-windshield-rear"></div>
      </div>
      <div class="hv-car-wheels hv-wheels-rear">
        <div class="hv-wheel"></div>
        <div class="hv-wheel"></div>
      </div>
    </div>

    <!-- Rear LED strip -->
    <div class="hv-row hv-row-rear">
      <span class="hv-tag">{t.rear}</span>
      <div class="hv-strip hv-rear" role="img" aria-label="Rear LED strip">
        <div class="hv-rear-bar"></div>
      </div>
    </div>
    <div class="hv-park-labels" aria-live="polite" aria-atomic="true">
      <span class="hv-ml hv-pl-safe">{t.parkSafe}</span>
      <span class="hv-ml hv-pl-warn">{t.parkWarn}</span>
      <span class="hv-ml hv-pl-danger">{t.parkDanger}</span>
    </div>
  </div>
</section>

<style>
  /* ── Container ─────────────────────────────────────────────── */
  .hv {
    margin: 2rem 0 2.5rem;
    padding: 1.5rem 1.75rem 1.75rem;
    background: var(--amb-cockpit, #06080E);
    border: 1px solid var(--amb-line, rgba(255,255,255,.08));
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,.5);
    overflow: hidden;
  }

  /* ── Header row ────────────────────────────────────────────── */
  .hv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .hv-eyebrow {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amb-text-4, #6B7488);
  }

  /* ── Mode labels (crossfade in sync with animations) ────────── */
  .hv-mode-labels,
  .hv-park-labels {
    position: relative;
    height: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .hv-park-labels {
    justify-content: flex-start;
    margin-top: 0.4rem;
    padding-left: calc(3.5rem + 1rem);
  }

  .hv-ml {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    position: absolute;
    white-space: nowrap;
    opacity: 0;
  }

  /* Front mode labels — sync with 20s hv-f-* animations */
  .hv-ml-ambient {
    color: var(--amb-violet-soft, #A38CFF);
    animation: ml-ambient 20s ease-in-out infinite;
  }
  .hv-ml-right {
    color: var(--amb-cyan, #19E3FF);
    animation: ml-right 20s ease-in-out infinite;
  }
  .hv-ml-left {
    color: var(--amb-cyan, #19E3FF);
    animation: ml-left 20s ease-in-out infinite;
  }
  .hv-ml-straight {
    color: #e0f8ff;
    animation: ml-straight 20s ease-in-out infinite;
  }

  /* Rear park labels — sync with 16s rear animations */
  .hv-pl-safe {
    color: #22C55E;
    animation: pl-safe 16s ease-in-out infinite;
  }
  .hv-pl-warn {
    color: #F59E0B;
    animation: pl-warn 16s ease-in-out infinite;
  }
  .hv-pl-danger {
    color: var(--amb-magenta, #FF2D9C);
    animation: pl-danger 16s ease-in-out infinite;
  }

  /* ── Strip rows ─────────────────────────────────────────────── */
  .hv-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .hv-row-rear {
    flex-direction: row-reverse;
    justify-content: flex-end;
  }
  .hv-row-rear .hv-tag {
    text-align: right;
  }

  .hv-tag {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--amb-text-4, #6B7488);
    width: 3.5rem;
    flex-shrink: 0;
  }

  /* ── LED Strips ─────────────────────────────────────────────── */
  .hv-strip {
    flex: 1;
    height: 10px;
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--amb-line, rgba(255,255,255,.08));
    position: relative;
    overflow: hidden;
    /* Simulate individual LED segments */
    mask-image: repeating-linear-gradient(
      90deg,
      #000 0px,
      #000 calc(100% / 28 - 2px),
      transparent calc(100% / 28 - 2px),
      transparent calc(100% / 28)
    );
  }

  /* Front strip glow syncs with modes */
  .hv-front {
    animation: front-glow 20s ease-in-out infinite;
  }

  /* ── Front LED state layers ─────────────────────────────────── */
  .hv-state {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
  }

  /* Ambient: dim full gradient */
  .hv-f-ambient {
    background: linear-gradient(90deg,
      rgba(25,227,255,.28) 0%,
      rgba(124,92,255,.38) 50%,
      rgba(255,45,156,.28) 100%
    );
    animation: fade-f-ambient 20s ease-in-out infinite;
  }

  /* Guide Right: cyan brightens toward right */
  .hv-f-right {
    background: linear-gradient(90deg,
      rgba(25,227,255,.08) 0%,
      rgba(25,227,255,.5) 50%,
      rgba(25,227,255,.95) 78%,
      rgba(25,227,255,.3) 100%
    );
    animation: fade-f-right 20s ease-in-out infinite;
  }

  /* Guide Left: cyan brightens toward left */
  .hv-f-left {
    background: linear-gradient(90deg,
      rgba(25,227,255,.3) 0%,
      rgba(25,227,255,.95) 22%,
      rgba(25,227,255,.5) 50%,
      rgba(25,227,255,.08) 100%
    );
    animation: fade-f-left 20s ease-in-out infinite;
  }

  /* Continue Straight: white/cyan center pulse */
  .hv-f-straight {
    background: linear-gradient(90deg,
      rgba(25,227,255,.1) 0%,
      rgba(220,250,255,.8) 30%,
      rgba(255,255,255,.96) 50%,
      rgba(220,250,255,.8) 70%,
      rgba(25,227,255,.1) 100%
    );
    animation: fade-f-straight 20s ease-in-out infinite;
  }

  /* ── Rear parking strip ─────────────────────────────────────── */
  .hv-rear {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    background: transparent;
    border-color: var(--amb-line, rgba(255,255,255,.08));
  }

  .hv-rear-bar {
    height: 100%;
    border-radius: 999px;
    animation: rear-park-cycle 16s ease-in-out infinite;
  }

  /* ── Car silhouette ─────────────────────────────────────────── */
  .hv-car {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding: 0.5rem 0;
  }

  .hv-car-wheels {
    display: flex;
    justify-content: space-between;
    width: min(400px, 80%);
    padding: 0 0.5rem;
  }

  .hv-wheel {
    width: 22px;
    height: 14px;
    border-radius: 4px;
    background: var(--amb-surface-3, #151A26);
    border: 1px solid var(--amb-line-strong, rgba(255,255,255,.14));
  }

  .hv-car-body {
    width: min(400px, 80%);
    background: var(--amb-surface, #0B0F18);
    border: 1px solid var(--amb-line-strong, rgba(255,255,255,.14));
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .hv-windshield {
    height: 24px;
    background: var(--amb-surface-3, #151A26);
    opacity: 0.7;
  }
  .hv-windshield-front { border-radius: 4px 4px 0 0; }
  .hv-windshield-rear  { border-radius: 0 0 4px 4px; }

  .hv-interior {
    flex: 1;
    min-height: 40px;
    background: var(--amb-surface-2, #0E121C);
    /* Subtle seat suggestion */
    background-image: repeating-linear-gradient(
      90deg,
      transparent 0%,
      transparent 45%,
      rgba(255,255,255,.03) 45%,
      rgba(255,255,255,.03) 55%,
      transparent 55%,
      transparent 100%
    );
  }

  /* ── Light-mode adjustments ─────────────────────────────────── */
  :global([data-theme='light']) .hv {
    background: #F4F6FB;
    border-color: rgba(0,0,0,.08);
    box-shadow: 0 4px 20px rgba(0,0,0,.08);
  }
  :global([data-theme='light']) .hv-car-body {
    background: #EEF2FA;
    border-color: rgba(0,0,0,.10);
  }
  :global([data-theme='light']) .hv-interior {
    background: #E4E9F4;
  }
  :global([data-theme='light']) .hv-windshield {
    background: #DDE2EC;
  }
  :global([data-theme='light']) .hv-wheel {
    background: #DDE2EC;
    border-color: rgba(0,0,0,.12);
  }
  :global([data-theme='light']) .hv-strip {
    border-color: rgba(0,0,0,.10);
  }
  :global([data-theme='light']) .hv-f-ambient {
    background: linear-gradient(90deg,
      rgba(0,150,176,.35) 0%,
      rgba(124,92,255,.45) 50%,
      rgba(204,0,107,.35) 100%
    );
  }

  /* ── Mobile ─────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hv { padding: 1rem; }
    .hv-header { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
    .hv-mode-labels { position: static; height: auto; justify-content: flex-start; }
    .hv-ml { position: static; }
    .hv-ml-ambient { display: block; }
    .hv-ml-right, .hv-ml-left, .hv-ml-straight { display: none; }
    .hv-tag { width: 2.8rem; font-size: 0.6rem; }
    .hv-park-labels { padding-left: calc(2.8rem + 1rem); }
  }

  /* ═══════════════════════════════════════════════════════════════
     KEYFRAMES — Front strip (20s cycle)
     0–15%   : Ambient
     15–40%  : Guide Right
     40–62%  : Guide Left
     62–78%  : Straight
     78–100% : Ambient
  ═══════════════════════════════════════════════════════════════ */

  @keyframes front-glow {
    0%, 12%  { box-shadow: 0 0 14px rgba(124,92,255,.3); }
    17%, 38% { box-shadow: 0 0 28px rgba(25,227,255,.65); }
    42%, 60% { box-shadow: 0 0 28px rgba(25,227,255,.65); }
    64%, 76% { box-shadow: 0 0 34px rgba(200,248,255,.6); }
    80%, 100%{ box-shadow: 0 0 14px rgba(124,92,255,.3); }
  }

  @keyframes fade-f-ambient {
    0%,  2%  { opacity: 1; }
    12%       { opacity: 0; }
    76%, 82%  { opacity: 0; }
    90%, 100% { opacity: 1; }
  }

  @keyframes fade-f-right {
    0%,  13% { opacity: 0; }
    18%, 37% { opacity: 1; }
    42%       { opacity: 0; }
    100%      { opacity: 0; }
  }

  @keyframes fade-f-left {
    0%,  40% { opacity: 0; }
    45%, 59% { opacity: 1; }
    64%       { opacity: 0; }
    100%      { opacity: 0; }
  }

  @keyframes fade-f-straight {
    0%,  62% { opacity: 0; }
    67%, 75% { opacity: 1; }
    80%       { opacity: 0; }
    100%      { opacity: 0; }
  }

  /* ── Mode label keyframes (match front strip) ─────────────── */
  @keyframes ml-ambient {
    0%,  2%  { opacity: 1; }
    10%       { opacity: 0; }
    78%, 84%  { opacity: 0; }
    92%, 100% { opacity: 1; }
  }
  @keyframes ml-right {
    0%,  14% { opacity: 0; }
    19%, 36% { opacity: 1; }
    41%       { opacity: 0; }
    100%      { opacity: 0; }
  }
  @keyframes ml-left {
    0%,  41% { opacity: 0; }
    46%, 58% { opacity: 1; }
    63%       { opacity: 0; }
    100%      { opacity: 0; }
  }
  @keyframes ml-straight {
    0%,  63% { opacity: 0; }
    68%, 74% { opacity: 1; }
    79%       { opacity: 0; }
    100%      { opacity: 0; }
  }

  /* ═══════════════════════════════════════════════════════════════
     KEYFRAMES — Rear strip (16s cycle)
     0–20%   : Safe (full green)
     25–50%  : Warning (60%, amber)
     55–75%  : Danger (25%, magenta)
     85–100% : Reset to safe
  ═══════════════════════════════════════════════════════════════ */

  @keyframes rear-park-cycle {
    0%, 18% {
      width: 100%;
      background: rgba(34,197,94,.72);
      box-shadow: 0 0 20px rgba(34,197,94,.5);
    }
    26%, 48% {
      width: 60%;
      background: rgba(245,158,11,.76);
      box-shadow: 0 0 24px rgba(245,158,11,.5);
    }
    56%, 74% {
      width: 26%;
      background: rgba(255,45,156,.88);
      box-shadow: 0 0 32px rgba(255,45,156,.7);
    }
    84%, 100% {
      width: 100%;
      background: rgba(34,197,94,.72);
      box-shadow: 0 0 20px rgba(34,197,94,.5);
    }
  }

  /* ── Park label keyframes (match rear strip, 16s) ─────────── */
  @keyframes pl-safe {
    0%, 16%  { opacity: 1; }
    23%       { opacity: 0; }
    82%, 88%  { opacity: 0; }
    96%, 100% { opacity: 1; }
  }
  @keyframes pl-warn {
    0%,  24% { opacity: 0; }
    29%, 47% { opacity: 1; }
    54%       { opacity: 0; }
    100%      { opacity: 0; }
  }
  @keyframes pl-danger {
    0%,  54% { opacity: 0; }
    59%, 73% { opacity: 1; }
    80%       { opacity: 0; }
    100%      { opacity: 0; }
  }
</style>
