{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "ambientnav",
      "bump-minor-pre-major": true,
      "changelog-sections": [
        { "type": "feat",     "section": "Features" },
        { "type": "fix",      "section": "Bug Fixes" },
        { "type": "docs",     "section": "Documentation" },
        { "type": "firmware", "section": "Firmware" },
        { "type": "chore",    "hidden": true }
      ],
      "extra-files": [
        {
          "type": "generic",
          "path": "firmware/front/src/config.h",
          "search-version-string": "#define FIRMWARE_VERSION \""
        },
        {
          "type": "generic",
          "path": "firmware/rear/src/config.h",
          "search-version-string": "#define FIRMWARE_VERSION \""
        }
      ]
    }
  }
}
